{
  "name": "ytmetrics-desktop",
  "version": "1.0.0",
  "description": "YTMetrics — десктоп-приложение (Windows/macOS/Linux)",
  "main": "main.js",
  "author": "YTMetrics",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ytmetrics.desktop",
    "productName": "YTMetrics",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "icon.png",
      "package.json"
    ],
    "protocols": {
      "name": "YTMetrics Auth",
      "schemes": ["ytmetrics"]
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png",
      "identity": null
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}

